# Copy this file to `.env` for local development, then fill in your values.
# Never commit `.env` — it is listed in .gitignore.
#
# For Claude Desktop / Cursor with the Azure-hosted MCP server, prefer putting
# these values in your MCP client config instead of Azure App Settings.
# See the Claude config example at the bottom of this file.

# From Salsify: My Profile > API Access > Show API Key (token only, no "Bearer " prefix)
SALSIFY_API_TOKEN=your-api-token

# From your Salsify org URL: https://app.salsify.com/orgs/{orgId}/...
SALSIFY_ORG_ID=s-999-999-999-999

# Optional: port for local HTTP server (Azure sets PORT automatically)
# PORT=3000

